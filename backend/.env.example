# Database
DATABASE_URL=sqlite:///./sql_app.db

# Authentication & Security
CRON_SECRET=super_secret_cron_token_123

# Local AI (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Cloud AI (Gemini - Primary)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_server_fallback_key
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Security (Required for User API keys)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_SECRET=

# Crawler & Worker Settings
CRAWLER_CONCURRENCY=3
CRAWLER_POLL_INTERVAL_SECONDS=10
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_MAX_PAGES=1

# External Integrations (Optional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Firebase (Required for some Admin Auth features)
FIREBASE_SERVICE_ACCOUNT=./serviceAccountKey.json
